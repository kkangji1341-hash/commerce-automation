# 데이터베이스 (로컬은 SQLite, 배포 환경은 Railway가 DATABASE_URL을 postgres://로 주입)
DATABASE_URL=sqlite+aiosqlite:///./commerce_automation.db

# JWT 서명 키 — 반드시 프로덕션에서는 무작위 값으로 교체할 것
SECRET_KEY=your-secret-key-change-in-production

# ---- 네이버 데이터랩(검색어트렌드) API — 검색 트렌드(12개월, 0-100 상대 지수) ----
# https://developers.naver.com 에서 "검색어트렌드" API를 추가한 앱의 자격증명
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- 네이버 검색 API(쇼핑) — 평균 판매가 / 판매자 수(proxy) ----
# 위 데이터랩과는 별개의 앱/자격증명이 필요하다 (같은 앱에 두 권한을 함께 못 붙이는 경우가 있음)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# ---- 네이버 검색광고 API — 절대 월간 검색량 ----
# https://searchad.naver.com API 사용 관리에서 발급 (HMAC-SHA256 서명 인증)
NAVER_AD_CUSTOMER_ID=
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
